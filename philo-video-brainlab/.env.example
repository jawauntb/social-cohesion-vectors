# ── project ───────────────────────────────────────────────────────────────
PROJECT_NAME=philo-video-brainlab
ENV=dev
LOG_LEVEL=INFO

# ── database (Postgres; Railway/Supabase/local) ───────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/philo_brainlab

# ── data layout ───────────────────────────────────────────────────────────
DATA_ROOT=./data
RAW_DIR=./data/raw
FEATURES_DIR=./data/features
MODELS_DIR=./data/models

# ── Modal (serverless GPU) ────────────────────────────────────────────────
MODAL_WORKSPACE=
MODAL_DEFAULT_GPU=A10G
BRAINLAB_MODAL_APP=philo-video-brainlab

# ── Meta models (gated on Hugging Face — request access, then read token) ──
HF_TOKEN=
TRIBE_MODEL_ID=facebook/tribe-v2
TRIBE_TARGET_LAYERS=-1,-2,-4
BRAIN2QWERTY_MODEL_ID=facebook/brain2qwerty

# ── feature-extraction models ─────────────────────────────────────────────
WHISPER_MODEL_ID=openai/whisper-large-v3
VISION_EMBED_MODEL_ID=openai/clip-vit-large-patch14
FRAME_SAMPLE_FPS=1.0

# ── optional LLM providers (editor-note generation, transcript cleanup) ────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── social platform ingestion (fill what you use) ─────────────────────────
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# ── frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=philo-video-brainlab
MODAL_PREDICT_ENDPOINT=
