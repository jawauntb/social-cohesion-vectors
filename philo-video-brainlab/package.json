{
  "name": "philo-video-brainlab",
  "version": "0.1.0",
  "private": true,
  "description": "Predict social engagement from TRIBE v2 brain-response trajectories.",
  "workspaces": [
    "apps/*",
    "packages/db"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "db:generate": "npm run generate -w @brainlab/db",
    "db:migrate": "npm run migrate -w @brainlab/db",
    "db:seed": "npm run seed -w @brainlab/db"
  },
  "engines": {
    "node": ">=20"
  }
}
