PROJECT_NAME=social_cohesion_vectors
ENV=dev
LOG_LEVEL=INFO

DATA_ROOT=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
FEATURES_DIR=./data/features
LABELS_DIR=./data/labels
TRAINING_DIR=./data/training
MODELS_DIR=./data/models
VECTORS_DIR=./data/models/vectors
REPORTS_DIR=./data/reports

RANDOM_SEED=42
DEV_SCENARIO_LIMIT=24

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_TOKEN=
HF_TOKEN=
WANDB_API_KEY=

MODAL_WORKSPACE=
MODAL_DEFAULT_GPU=A10G
SCV_OPEN_LLM_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
SCV_OPEN_LLM_ACTIVATION_LAYER=-1
SCV_MODAL_APP_BASE_NAME=social-cohesion-vectors

# Video analyzer (TRIBE brain-response -> engagement) — reuses HF_TOKEN above.
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_TARGET_LAYER=-1
TRIBE_GIT_REF=main
FRAME_SAMPLE_FPS=1.0
# Deployed endpoint URL the site calls (from `modal deploy ... video_analyzer`).
VIDEO_ANALYZER_ENDPOINT=
